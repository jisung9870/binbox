#!/usr/bin/env bash
# tmux-layout
# fzf로 레이아웃 선택 후 세션 생성
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
LAYOUT_DIR="${SCRIPT_DIR}/tmux-layouts"

usage() {
  cat <<'EOF'
tmux-layout — fzf로 레이아웃 선택 후 tmux 세션 생성

사용법:
  tmux-layout [세션이름] [프로젝트경로]

예시:
  tmux-layout                       # 레이아웃 선택 후 이름 입력, $PWD 사용
  tmux-layout my-proj ~/work/proj
EOF
}

case "${1:-}" in
  -h|--help|help) usage; exit 0 ;;
esac

SESSION_NAME="${1:-}"
PROJECT_DIR="${2:-$PWD}"

command -v tmux >/dev/null || { echo "tmux가 설치되지 않았습니다." >&2; exit 1; }
if ! command -v fzf &>/dev/null; then
  echo "fzf가 설치되지 않았습니다. 'brew install fzf'로 설치하세요." >&2
  exit 1
fi

if [[ ! -d "$LAYOUT_DIR" ]]; then
  echo "레이아웃 디렉토리가 없습니다: $LAYOUT_DIR" >&2
  exit 1
fi

layouts=$(find "$LAYOUT_DIR" -maxdepth 1 -type f -name '*-layout' -perm -111 -print 2>/dev/null | sed 's#.*/##; s/-layout$//' | sort)

if [[ -z "$layouts" ]]; then
  echo "사용 가능한 레이아웃이 없습니다."
  exit 1
fi

selected=$(printf '%s\n' "$layouts" | fzf --prompt="레이아웃 선택: " || true)

if [[ -z "$selected" ]]; then
  exit 0
fi

# 세션 이름이 없으면 입력 받기
if [[ -z "$SESSION_NAME" ]]; then
  read -r -p "세션 이름: " SESSION_NAME
  if [[ -z "$SESSION_NAME" ]]; then
    SESSION_NAME="${selected}-$(date +%H%M)"
  fi
fi

if [[ ! -d "$PROJECT_DIR" ]]; then
  echo "프로젝트 디렉토리가 없습니다: $PROJECT_DIR" >&2
  exit 1
fi

exec "$LAYOUT_DIR/${selected}-layout" "$SESSION_NAME" "$PROJECT_DIR"
