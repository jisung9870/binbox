#!/usr/bin/env bash
set -euo pipefail

command -v tmux >/dev/null || { echo "tmux가 설치되지 않았습니다." >&2; exit 1; }
command -v fzf >/dev/null || { echo "fzf가 설치되지 않았습니다. 'brew install fzf'로 설치하세요." >&2; exit 1; }

sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null || true)

if [[ -z "$sessions" ]]; then
    echo "실행 중인 세션이 없습니다."
    exit 0
fi

to_kill=$(printf '%s\n' "$sessions" | fzf --multi --prompt="삭제할 세션 선택 (Tab으로 다중 선택): " || true)

if [[ -z "$to_kill" ]]; then
    echo "선택 취소"
    exit 0
fi

# 선택한 세션들 제거
printf '%s\n' "$to_kill" | while read -r session; do
    tmux kill-session -t "$session"
    echo "✓ $session 제거됨"
done
