#!/usr/bin/env bash

set -euo pipefail

_self=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")
BINBOX_DIR=$(cd "$(dirname "$_self")" && pwd)
# shellcheck source=lib/common.sh
source "$BINBOX_DIR/lib/common.sh" || { echo "lib/common.sh not found" >&2; exit 1; }

TOOL="${1:-}"
CONFIG_DIR="$BINBOX_DIR/dx.d"
IMAGE_DIR="$BINBOX_DIR/images"

usage() {
  cat <<'EOF'
Usage:
  dx --list
  dx --help [tool]
  dx --build <tool>
  dx <tool> [args...]

Examples:
  dx --list
  dx --help ansible
  dx --build ansible
  dx terraform plan
  dx ubuntu
EOF
}

list_tools() {
  find "$CONFIG_DIR" -maxdepth 1 -type f -print 2>/dev/null | sed 's#.*/##' | sort
}

load_tool() {
  local tool="$1"
  if [[ ! -f "$CONFIG_DIR/$tool" ]]; then
    usage >&2
    die "Error: Unknown tool '$tool'"
  fi

  unset DOCKER_IMAGE DOCKER_OPTS
  DOCKER_IMAGE=""
  DOCKER_OPTS=()

  # shellcheck source=/dev/null
  source "$CONFIG_DIR/$tool"
  [[ -n "$DOCKER_IMAGE" ]] || die "DOCKER_IMAGE is not set in $CONFIG_DIR/$tool"
  if ! declare -p DOCKER_OPTS 2>/dev/null | grep -q '^declare \-[^ ]*a[^ ]* DOCKER_OPTS='; then
    die "DOCKER_OPTS must be an array in $CONFIG_DIR/$tool"
  fi
}

tool_help() {
  local tool="$1"
  load_tool "$tool"

  echo "Tool: $tool"
  echo "Image: $DOCKER_IMAGE"
  echo "Config: ok"
  if [[ -f "$IMAGE_DIR/$tool/Dockerfile" ]]; then
    echo "Build: dx --build $tool"
  else
    echo "Build: no local Dockerfile at images/$tool/Dockerfile"
  fi
  echo
  echo "Run:"
  echo "  dx $tool [args...]"
  echo "  dx $tool"
}

build_tool() {
  local tool="$1"
  load_tool "$tool"

  local dockerfile_dir="$IMAGE_DIR/$tool"
  if [[ ! -f "$dockerfile_dir/Dockerfile" ]]; then
    die "No local Dockerfile for '$tool': $dockerfile_dir/Dockerfile"
  fi

  need_cmd docker "brew install --cask docker"
  docker build -t "$DOCKER_IMAGE" "$dockerfile_dir"
}

if [[ -z "$TOOL" ]]; then
  usage
  exit 1
fi

case "$TOOL" in
  --list|list)
    list_tools
    exit 0
    ;;
  -h|--help|help)
    if [[ -n "${2:-}" ]]; then
      tool_help "$2"
    else
      usage
      echo
      echo "Available tools:"
      tools=$(list_tools)
      if [[ -n "$tools" ]]; then
        echo "$tools"
      else
        echo " (none)"
      fi
    fi
    exit 0
    ;;
  --build|build)
    if [[ -z "${2:-}" ]]; then
      die "Usage: dx --build <tool>"
    fi
    build_tool "$2"
    exit 0
    ;;
esac

need_cmd docker "brew install --cask docker"

load_tool "$TOOL"
shift
if [[ $# -eq 0 ]]; then
  set -- bash
fi
docker_tty_opts=(-i)
if [[ -t 0 && -t 1 ]]; then
  docker_tty_opts=(-it)
fi
docker_args=(run --rm "${docker_tty_opts[@]}" -v "$(pwd):/work" -w /work)
if ((${#DOCKER_OPTS[@]})); then
  docker_args+=("${DOCKER_OPTS[@]}")
fi
docker_args+=("$DOCKER_IMAGE" "$@")
docker "${docker_args[@]}"
