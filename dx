#!/usr/bin/env bash

set -euo pipefail

TOOL="${1:-}"
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
CONFIG_DIR="${SCRIPT_DIR}/dx.d"
IMAGE_DIR="${SCRIPT_DIR}/images"

usage() {
  cat <<'EOF'
Usage:
  dx --list
  dx --help [tool]
  dx --build <tool>
  dx <tool> [args...]

Examples:
  dx --list
  dx --help ansible
  dx --build ansible
  dx terraform plan
  dx ubuntu
EOF
}

list_tools() {
  find "$CONFIG_DIR" -maxdepth 1 -type f -print 2>/dev/null | sed 's#.*/##' | sort
}

load_tool() {
  local tool="$1"
  if [[ ! -f "$CONFIG_DIR/$tool" ]]; then
    echo "Error: Unknown tool '$tool'" >&2
    usage >&2
    exit 1
  fi

  unset DOCKER_IMAGE DOCKER_OPTS
  DOCKER_IMAGE=""
  DOCKER_OPTS=()

  # shellcheck source=/dev/null
  source "$CONFIG_DIR/$tool"
  [[ -n "$DOCKER_IMAGE" ]] || { echo "DOCKER_IMAGE is not set in $CONFIG_DIR/$tool" >&2; exit 1; }
  if ! declare -p DOCKER_OPTS 2>/dev/null | grep -q '^declare \-[^ ]*a[^ ]* DOCKER_OPTS='; then
    echo "DOCKER_OPTS must be an array in $CONFIG_DIR/$tool" >&2
    exit 1
  fi
}

tool_help() {
  local tool="$1"
  load_tool "$tool"

  echo "Tool: $tool"
  echo "Image: $DOCKER_IMAGE"
  echo "Config: ok"
  if [[ -f "$IMAGE_DIR/$tool/Dockerfile" ]]; then
    echo "Build: dx --build $tool"
  else
    echo "Build: no local Dockerfile at images/$tool/Dockerfile"
  fi
  echo
  echo "Run:"
  echo "  dx $tool [args...]"
  echo "  dx $tool"
}

build_tool() {
  local tool="$1"
  load_tool "$tool"

  local dockerfile_dir="$IMAGE_DIR/$tool"
  if [[ ! -f "$dockerfile_dir/Dockerfile" ]]; then
    echo "No local Dockerfile for '$tool': $dockerfile_dir/Dockerfile" >&2
    exit 1
  fi

  command -v docker >/dev/null || { echo "docker not found in PATH" >&2; exit 1; }
  docker build -t "$DOCKER_IMAGE" "$dockerfile_dir"
}

if [[ -z "$TOOL" ]]; then
  usage
  exit 1
fi

case "$TOOL" in
  --list|list)
    list_tools
    exit 0
    ;;
  -h|--help|help)
    if [[ -n "${2:-}" ]]; then
      tool_help "$2"
    else
      usage
      echo
      echo "Available tools:"
      tools=$(list_tools)
      if [[ -n "$tools" ]]; then
        echo "$tools"
      else
        echo " (none)"
      fi
    fi
    exit 0
    ;;
  --build|build)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: dx --build <tool>" >&2
      exit 1
    fi
    build_tool "$2"
    exit 0
    ;;
esac

command -v docker >/dev/null || { echo "docker not found in PATH" >&2; exit 1; }

load_tool "$TOOL"
shift
if [[ $# -eq 0 ]]; then
  set -- bash
fi
docker_tty_opts=(-i)
if [[ -t 0 && -t 1 ]]; then
  docker_tty_opts=(-it)
fi
docker_args=(run --rm "${docker_tty_opts[@]}" -v "$(pwd):/work" -w /work)
if ((${#DOCKER_OPTS[@]})); then
  docker_args+=("${DOCKER_OPTS[@]}")
fi
docker_args+=("$DOCKER_IMAGE" "$@")
docker "${docker_args[@]}"
