#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/tmux-sessionizer/dirs"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/tmux-sessionizer"
RECENT_FILE="$STATE_DIR/recent"

if [[ -f "$CONFIG_FILE" ]]; then
  PROJECT_DIRS=()
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    line="${line/#\~/$HOME}"
    PROJECT_DIRS+=("$line")
  done <"$CONFIG_FILE"
else
  PROJECT_DIRS=("$HOME/home/projects" "$HOME/home/work")
fi

command -v tmux >/dev/null || { echo "tmux가 설치되지 않았습니다." >&2; exit 1; }
if ! command -v fzf &>/dev/null; then
  echo "fzf가 설치되지 않았습니다. 'brew install fzf'로 설치하세요."
  exit 1
fi

if [[ ${#PROJECT_DIRS[@]} -eq 0 ]]; then
  echo "프로젝트 디렉토리가 설정되어 있지 않습니다: $CONFIG_FILE" >&2
  exit 1
fi

valid_dirs=()
for dir in "${PROJECT_DIRS[@]}"; do
  if [[ -d "$dir" ]]; then
    valid_dirs+=("$dir")
  fi
done

if [[ ${#valid_dirs[@]} -eq 0 ]]; then
  echo "사용 가능한 프로젝트 디렉토리가 없습니다." >&2
  echo "설정 파일을 확인하세요: $CONFIG_FILE" >&2
  exit 1
fi

read_candidates() {
  find "${valid_dirs[@]}" -mindepth 1 -maxdepth 1 -type d ! -name '.*' -print 2>/dev/null | sort -u
}

ordered_candidates() {
  local candidates
  candidates=$(read_candidates)
  [[ -n "$candidates" ]] || return 0

  if [[ -f "$RECENT_FILE" ]]; then
    while IFS= read -r recent; do
      [[ -n "$recent" ]] || continue
      if printf '%s\n' "$candidates" | grep -Fxq "$recent"; then
        printf '%s\n' "$recent"
      fi
    done <"$RECENT_FILE"
  fi

  printf '%s\n' "$candidates" | while IFS= read -r candidate; do
    if [[ -f "$RECENT_FILE" ]] && grep -Fxq "$candidate" "$RECENT_FILE"; then
      continue
    fi
    printf '%s\n' "$candidate"
  done
}

record_recent() {
  local selected_path="$1"
  mkdir -p "$STATE_DIR"
  {
    printf '%s\n' "$selected_path"
    if [[ -f "$RECENT_FILE" ]]; then
      grep -Fxv "$selected_path" "$RECENT_FILE" | while IFS= read -r recent; do
        [[ -d "$recent" ]] && printf '%s\n' "$recent"
      done
    fi
  } | awk 'NF && !seen[$0]++ {print}' | head -50 >"${RECENT_FILE}.tmp"
  mv "${RECENT_FILE}.tmp" "$RECENT_FILE"
}

selected=$(ordered_candidates | fzf || true)

if [[ -z $selected ]]; then
  exit 0
fi

record_recent "$selected"

selected_name=$(basename "$selected" | tr '.:' '__')

tmux_running=$(pgrep tmux || true)

if [[ -z ${TMUX:-} ]] && [[ -z $tmux_running ]]; then
  tmux new-session -s "$selected_name" -c "$selected"
  exit 0
fi

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
  tmux new-session -ds "$selected_name" -c "$selected"
fi

if [[ -n ${TMUX:-} ]]; then
  tmux switch-client -t "$selected_name"
else
  tmux attach-session -t "$selected_name"
fi
