#!/usr/bin/env bash
# kns — fzf 기반 kubectl namespace 전환
set -euo pipefail

_self=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")
BINBOX_DIR=$(cd "$(dirname "$_self")" && pwd)
# shellcheck source=lib/common.sh
source "$BINBOX_DIR/lib/common.sh" || { echo "lib/common.sh not found" >&2; exit 1; }

usage() {
  cat <<'EOF'
kns — fzf 기반 kubectl namespace 전환

사용법:
  kns               # fzf로 namespace 선택
  kns <namespace>   # 직접 전환

예시:
  kns monitoring
EOF
}

case "${1:-}" in
  -h|--help|help) usage; exit 0 ;;
esac

need_cmd kubectl "brew install kubectl"

current=$(kubectl config view --minify --output 'jsonpath={..namespace}' 2>/dev/null || true)
current=${current:-default}

# 인자가 있으면 직접 전환
if [[ -n "${1:-}" ]]; then
  kubectl config set-context --current --namespace="$1"
  exit $?
fi

need_cmd fzf "brew install fzf"

namespaces=$(kubectl get namespaces -o jsonpath='{.items[*].metadata.name}' 2>/dev/null | tr ' ' '\n' || true)

[[ -n "$namespaces" ]] || die "namespace 목록을 가져올 수 없습니다."

selected=$(printf '%s\n' "$namespaces" | fzf_pick \
  --prompt="namespace 선택 (현재: ${current}): " \
  --header="현재: ${current}" \
  --preview="kubectl get pods -n {} --no-headers 2>/dev/null | head -20" \
  --preview-window=down:10:wrap)

if [[ -n "$selected" ]]; then
  kubectl config set-context --current --namespace="$selected"
  echo "namespace 전환: $selected"
fi
