#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)

command -v shellcheck >/dev/null || {
  echo "shellcheck not found in PATH" >&2
  echo "Install it first, for example: brew install shellcheck" >&2
  exit 1
}

# bash shebang을 가진 최상위 스크립트 + tmux-layouts + lib 자동 탐색
targets=()
while IFS= read -r file; do
  head -1 "$file" 2>/dev/null | grep -q '^#!/usr/bin/env bash' || continue
  targets+=("$file")
done < <(find "$SCRIPT_DIR" "$SCRIPT_DIR/tmux-layouts" "$SCRIPT_DIR/lib" \
  -maxdepth 1 -type f -print 2>/dev/null | sort -u)

if [[ ${#targets[@]} -eq 0 ]]; then
  echo "No shell scripts found to check." >&2
  exit 1
fi

# -x: source된 lib/*.sh를 따라 들어가 검사
# -P SCRIPTDIR: source= 지시자를 cwd가 아닌 스크립트 위치 기준으로 해석
#   (없으면 repo root 밖에서 실행 시 SC1091로 실패)
shellcheck -x -P SCRIPTDIR "${targets[@]}"

# dx.d 설정 조각 (shebang 없음, dx가 source) — bash 문법으로 별도 검사
dxd_files=()
while IFS= read -r file; do
  dxd_files+=("$file")
done < <(find "$SCRIPT_DIR/dx.d" -maxdepth 1 -type f -print 2>/dev/null | sort)

if [[ ${#dxd_files[@]} -gt 0 ]]; then
  shellcheck -s bash "${dxd_files[@]}"
fi

echo "shellcheck passed ($((${#targets[@]} + ${#dxd_files[@]})) files)"
