#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)

command -v shellcheck >/dev/null || {
  echo "shellcheck not found in PATH" >&2
  echo "Install it first, for example: brew install shellcheck" >&2
  exit 1
}

files=(
  agents
  binbox-check
  binbox-doctor
  dx
  gitroot
  kctx
  kns
  md2jira
  portcheck
  tfplan
  tfsum
  tmux-attach
  tmux-kill-pattern
  tmux-kill-sessions
  tmux-layout
  tmux-sessionizer
)

layout_files=()
while IFS= read -r file; do
  layout_files+=("$file")
done < <(find "$SCRIPT_DIR/tmux-layouts" -maxdepth 1 -type f -print 2>/dev/null | sort)

targets=()
for file in "${files[@]}"; do
  if [[ -f "$SCRIPT_DIR/$file" ]]; then
    targets+=("$SCRIPT_DIR/$file")
  fi
done
targets+=("${layout_files[@]}")

if [[ ${#targets[@]} -eq 0 ]]; then
  echo "No shell scripts found to check." >&2
  exit 1
fi

shellcheck "${targets[@]}"
echo "shellcheck passed (${#targets[@]} files)"
