#!/usr/bin/env bash
# awsp — fzf 기반 AWS_PROFILE 전환
# 자식 프로세스는 부모 셸의 환경변수를 바꿀 수 없으므로 export 문을 stdout으로 출력한다.
# eval "$(awsp)" 로 사용하거나 .zshrc에 alias awsp='eval "$(command awsp)"' 등록.
set -euo pipefail

_self=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")
BINBOX_DIR=$(cd "$(dirname "$_self")/.." && pwd)
# shellcheck source=../lib/common.sh
source "$BINBOX_DIR/lib/common.sh" || { echo "lib/common.sh not found" >&2; exit 1; }

usage() {
  cat <<'EOF'
awsp — fzf 기반 AWS_PROFILE 전환

사용법:
  eval "$(awsp)"               # fzf로 profile 선택
  eval "$(awsp <profile>)"     # 직접 지정
  eval "$(awsp -r [profile])"  # profile의 region도 AWS_REGION으로 export

설정: aliases.zsh가 awsp() { eval "$(bb awsp "$@")"; } 함수를 제공한다.
EOF
}

with_region=0
selected=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help|help) usage; exit 0 ;;
    -r|--region) with_region=1; shift ;;
    -*) die "알 수 없는 옵션: $1" ;;
    *) selected="$1"; shift ;;
  esac
done

profiles=""
if command -v aws >/dev/null 2>&1; then
  profiles=$(aws configure list-profiles 2>/dev/null || true)
fi
if [[ -z "$profiles" && -f "$HOME/.aws/config" ]]; then
  profiles=$(grep -oE '^\[profile [^]]+\]' "$HOME/.aws/config" | sed 's/^\[profile //; s/\]$//' || true)
  if grep -qE '^\[default\]' "$HOME/.aws/config"; then
    profiles=$(printf 'default\n%s\n' "$profiles")
  fi
fi

[[ -n "$profiles" ]] || die "AWS profile을 찾을 수 없습니다. (~/.aws/config 확인)"

if [[ -n "$selected" ]]; then
  printf '%s\n' "$profiles" | grep -Fxq "$selected" || die "존재하지 않는 profile: $selected"
else
  need_cmd fzf "brew install fzf"
  current="${AWS_PROFILE:-}"
  selected=$(printf '%s\n' "$profiles" | fzf_pick \
    --prompt="profile 선택 (현재: ${current:-없음}): " \
    --header="현재: ${current:-없음}")
  [[ -n "$selected" ]] || exit 0
fi

# eval 없이 실행하면 아무 효과가 없으므로 stdout이 TTY면 안내
if [[ -t 1 ]]; then
  echo "환경변수를 실제로 바꾸려면 eval로 실행하세요:" >&2
  echo "  eval \"\$(awsp)\"  또는 alias awsp='eval \"\$(command awsp)\"'" >&2
fi

printf 'export AWS_PROFILE=%q\n' "$selected"
echo "AWS_PROFILE=${selected}" >&2

# -r: profile에 설정된 region을 AWS_REGION으로 함께 export
if [[ "$with_region" -eq 1 ]]; then
  region=""
  if command -v aws >/dev/null 2>&1; then
    region=$(aws configure get region --profile "$selected" 2>/dev/null || true)
  fi
  if [[ -z "$region" && -f "$HOME/.aws/config" ]]; then
    region=$(awk -v p="$selected" '
      /^\[/ { insec = ($0 == "[profile " p "]" || (p == "default" && $0 == "[default]")) }
      insec && /^[[:space:]]*region[[:space:]]*=/ { sub(/^[^=]*=[[:space:]]*/, ""); print; exit }
    ' "$HOME/.aws/config")
  fi
  [[ -n "$region" ]] || die "profile '$selected'에 region이 설정되어 있지 않습니다."
  printf 'export AWS_REGION=%q\n' "$region"
  echo "AWS_REGION=${region}" >&2
fi
