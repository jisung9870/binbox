#!/usr/bin/env bash
# assm — fzf로 EC2 인스턴스 선택 후 SSM 세션 접속 / 포트포워딩
set -euo pipefail

_self=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")
BINBOX_DIR=$(cd "$(dirname "$_self")/.." && pwd)
# shellcheck source=../lib/common.sh
source "$BINBOX_DIR/lib/common.sh" || { echo "lib/common.sh not found" >&2; exit 1; }

usage() {
  cat <<'EOF'
assm — fzf로 EC2 인스턴스 선택 후 SSM 세션 접속 / 포트포워딩

사용법:
  assm                          # 실행 중인 인스턴스에서 선택 → 셸 접속
  assm <instance-id>            # 직접 접속
  assm pf <포트> [로컬포트]       # 인스턴스 선택 → 인스턴스 포트를 로컬로 포워딩
  assm pf <호스트:포트> [로컬포트] # 인스턴스 경유 원격 호스트 포워딩 (RDS/내부 서비스)
  assm pf <instance-id> <대상> [로컬포트]  # 인스턴스 직접 지정

예시:
  assm pf 8080                  # localhost:8080 → 인스턴스:8080
  assm pf mydb.internal:5432 15432   # localhost:15432 → (인스턴스 경유) mydb:5432

profile/region은 AWS_PROFILE / AWS_REGION 환경변수를 따른다. (awsp/wenv와 연동)

요구 사항:
  aws cli, session-manager-plugin
  (brew install awscli session-manager-plugin)
EOF
}

_valid_port() {
  [[ "$1" =~ ^[0-9]+$ ]] && (( $1 >= 1 && $1 <= 65535 ))
}

# 실행 중인 인스턴스를 fzf로 선택 — stdout: instance-id, 취소 시 빈 출력
_pick_instance() {
  need_cmd fzf "brew install fzf"

  local instances selected
  # shellcheck disable=SC2016  # 백틱은 JMESPath 리터럴 문법
  instances=$(aws ec2 describe-instances \
    --filters Name=instance-state-name,Values=running \
    --query 'Reservations[].Instances[].[InstanceId, Tags[?Key==`Name`]|[0].Value, PrivateIpAddress, InstanceType]' \
    --output text 2>/dev/null || true)

  [[ -n "$instances" ]] || die "실행 중인 인스턴스가 없거나 조회에 실패했습니다. (AWS_PROFILE: ${AWS_PROFILE:-없음})"

  selected=$(printf '%s\n' "$instances" | column -t | fzf_pick \
    --prompt="인스턴스 선택 (profile: ${AWS_PROFILE:-default}): " \
    --header="InstanceId  Name  PrivateIp  Type")

  [[ -n "$selected" ]] || return 0
  printf '%s' "$selected" | awk '{print $1}'
}

cmd_pf() {
  need_cmd aws "brew install awscli"
  need_cmd session-manager-plugin "brew install session-manager-plugin"

  local instance_id="" target local_port host="" port doc params
  if [[ "${1:-}" =~ ^i-[0-9a-fA-F]{8,}$ ]]; then
    instance_id="$1"
    shift
  fi
  target="${1:-}"
  [[ -n "$target" ]] || { usage >&2; die "포워딩 대상(포트 또는 호스트:포트)을 지정하세요."; }
  local_port="${2:-}"
  [[ $# -le 2 ]] || die "알 수 없는 인자: $3"

  if [[ "$target" == *:* ]]; then
    host="${target%:*}"
    port="${target##*:}"
    [[ "$host" =~ ^[A-Za-z0-9._-]+$ ]] || die "올바른 호스트가 아닙니다: $host"
    doc="AWS-StartPortForwardingSessionToRemoteHost"
  else
    port="$target"
    doc="AWS-StartPortForwardingSession"
  fi
  _valid_port "$port" || die "올바른 포트 번호가 아닙니다: $port"
  [[ -n "$local_port" ]] || local_port="$port"
  _valid_port "$local_port" || die "올바른 로컬 포트 번호가 아닙니다: $local_port"

  if [[ -z "$instance_id" ]]; then
    instance_id=$(_pick_instance)
    [[ -n "$instance_id" ]] || exit 0
  fi

  # 값은 위에서 검증됨 (port/local_port: 숫자, host: [A-Za-z0-9._-]) — JSON 직접 조립 안전
  if [[ -n "$host" ]]; then
    params="{\"host\":[\"$host\"],\"portNumber\":[\"$port\"],\"localPortNumber\":[\"$local_port\"]}"
  else
    params="{\"portNumber\":[\"$port\"],\"localPortNumber\":[\"$local_port\"]}"
  fi

  echo "→ 포트포워딩: localhost:$local_port → ${host:+$host:}$port (via $instance_id)" >&2
  exec aws ssm start-session --target "$instance_id" \
    --document-name "$doc" --parameters "$params"
}

case "${1:-}" in
  -h|--help|help) usage; exit 0 ;;
  pf) shift; cmd_pf "$@" ;;
esac

need_cmd aws "brew install awscli"
need_cmd session-manager-plugin "brew install session-manager-plugin"

# 인자가 있으면 직접 접속
if [[ -n "${1:-}" ]]; then
  exec aws ssm start-session --target "$1"
fi

instance_id=$(_pick_instance)
[[ -n "$instance_id" ]] || exit 0
echo "→ SSM 세션 시작: $instance_id"
exec aws ssm start-session --target "$instance_id"
