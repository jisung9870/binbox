#!/usr/bin/env bash
# binbox-setup — 초기 설정 자동화 (bb 심볼릭 링크 + 셸 rc 등록). 재실행 안전(멱등).
set -euo pipefail

_self=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")
BINBOX_DIR=$(cd "$(dirname "$_self")/.." && pwd)
# shellcheck source=../lib/common.sh
source "$BINBOX_DIR/lib/common.sh" || { echo "lib/common.sh not found" >&2; exit 1; }

MARK_BEGIN='# >>> binbox >>>'
MARK_END='# <<< binbox <<<'

usage() {
  cat <<'EOF'
binbox-setup — 초기 설정 자동화 (재실행 안전)

  1. bb 실행 권한 부여
  2. ~/.local/bin/bb 심볼릭 링크 생성
  3. 셸 감지 후 rc 파일(.zshrc/.bashrc)에 binbox 블록 등록
     (블록은 repo의 shell/init.* 를 source — 이후 변경은 bb upgrade로 반영)

사용법:
  bb setup [--shell zsh|bash]

옵션:
  --shell   rc를 구성할 셸 지정 (기본: $SHELL 자동 감지)
EOF
}

SHELL_OVERRIDE=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help|help) usage; exit 0 ;;
    --shell)
      SHELL_OVERRIDE="${2:-}"
      case "$SHELL_OVERRIDE" in
        zsh|bash) ;;
        *) die "지원하지 않는 셸: ${SHELL_OVERRIDE:-(없음)}" "사용법: bb setup --shell zsh|bash" ;;
      esac
      shift 2
      ;;
    *) usage >&2; die "알 수 없는 옵션: $1" ;;
  esac
done

# make install의 chmod 역할 흡수 (zip 다운로드 등 실행 비트 없는 체크아웃 대비)
ensure_exec_bits() {
  chmod +x "$BINBOX_DIR/bb"
  find "$BINBOX_DIR/libexec" "$BINBOX_DIR/tmux-layouts" -maxdepth 1 -type f -exec chmod +x {} \;
}

resolve_path() {
  readlink -f "$1" 2>/dev/null || readlink "$1" 2>/dev/null || printf '%s' "$1"
}

link_bb() {
  local bindir="$HOME/.local/bin" link target
  link="$bindir/bb"
  target="$BINBOX_DIR/bb"

  [[ -e "$bindir" && ! -d "$bindir" ]] && die "디렉토리가 아닙니다: $bindir" "직접 정리 후 다시 실행하세요."
  mkdir -p "$bindir"

  if [[ -L "$link" ]]; then
    if [[ "$(resolve_path "$link")" == "$(resolve_path "$target")" ]]; then
      echo "✓ 링크 이미 설정됨: $link"
      return 0
    fi
    echo "기존 링크 대상 교체: $(readlink "$link") → $target"
    ln -sf "$target" "$link"
  elif [[ -e "$link" ]]; then
    confirm "bb가 이미 존재합니다($link). 백업 후 교체할까요?" ||
      die "중단했습니다. $link 를 직접 정리 후 다시 실행하세요."
    local bak
    bak="$link.bak.$(date +%Y%m%d%H%M%S)"
    mv "$link" "$bak"
    echo "백업: $bak"
    ln -s "$target" "$link"
  else
    ln -s "$target" "$link"
  fi
  echo "✓ 링크 생성: $link → $target"
}

detect_shell() {
  if [[ -n "$SHELL_OVERRIDE" ]]; then
    printf '%s' "$SHELL_OVERRIDE"
    return 0
  fi
  case "$(basename "${SHELL:-}")" in
    zsh) printf 'zsh'; return 0 ;;
    bash) printf 'bash'; return 0 ;;
  esac
  # $SHELL 없음/기타 셸 → rc 파일 존재로 추정
  [[ -f "${ZDOTDIR:-$HOME}/.zshrc" ]] && { printf 'zsh'; return 0; }
  [[ -f "$HOME/.bashrc" ]] && { printf 'bash'; return 0; }
  die "셸을 감지하지 못했습니다." "bb setup --shell zsh|bash 로 지정하세요."
}

rc_path() {
  case "$1" in
    zsh) printf '%s' "${ZDOTDIR:-$HOME}/.zshrc" ;;
    bash) printf '%s' "$HOME/.bashrc" ;;
  esac
}

build_block() {
  local init="$BINBOX_DIR/shell/init.$1"
  printf '%s\n' \
    "$MARK_BEGIN" \
    "# 이 블록은 'bb setup'이 관리합니다. 직접 수정하지 마세요 (재실행 시 갱신)." \
    "if [ -f \"$init\" ]; then" \
    "  . \"$init\"" \
    "fi" \
    "$MARK_END"
}

update_rc() {
  local rc="$1" desired="$2" b e current tmp

  if [[ ! -e "$rc" ]]; then
    printf '%s\n' "$desired" >"$rc"
    echo "✓ 생성: $rc"
    return 0
  fi

  b=$(grep -cxF "$MARK_BEGIN" "$rc" || true)
  e=$(grep -cxF "$MARK_END" "$rc" || true)

  if [[ "$b" -eq 0 && "$e" -eq 0 ]]; then
    [[ -s "$rc" ]] && printf '\n' >>"$rc"
    printf '%s\n' "$desired" >>"$rc"
    echo "✓ 블록 추가: $rc"
    return 0
  fi

  [[ "$b" -eq 1 && "$e" -eq 1 ]] ||
    die "binbox 마커가 손상되었습니다: $rc" "블록($MARK_BEGIN ... $MARK_END)을 직접 정리 후 다시 실행하세요."
  [[ "$(grep -nxF "$MARK_BEGIN" "$rc" | cut -d: -f1)" -lt "$(grep -nxF "$MARK_END" "$rc" | cut -d: -f1)" ]] ||
    die "binbox 마커 순서가 잘못되었습니다: $rc" "블록을 직접 정리 후 다시 실행하세요."

  current=$(awk -v b="$MARK_BEGIN" -v e="$MARK_END" '$0==b{f=1} f{print} $0==e{f=0}' "$rc")
  if [[ "$current" == "$desired" ]]; then
    echo "✓ 이미 최신: $rc"
    return 0
  fi

  cp -p "$rc" "$rc.bak.binbox"
  tmp=$(mktemp "${TMPDIR:-/tmp}/binbox-setup.XXXXXX")
  # 블록을 기존 위치에서 교체 (사용자가 블록을 compinit 위로 옮겼어도 위치 유지)
  # 멀티라인 블록은 awk -v로 못 넘긴다 (BSD awk: newline in string) → 앞/블록/뒤 3단계로 조립
  awk -v b="$MARK_BEGIN" '$0==b{exit} {print}' "$rc" >"$tmp"
  printf '%s\n' "$desired" >>"$tmp"
  awk -v e="$MARK_END" 'f{print} $0==e{f=1}' "$rc" >>"$tmp"
  cat "$tmp" >"$rc" # cat >로 써서 rc가 심볼릭 링크(dotfiles repo)여도 유지
  rm -f "$tmp"
  echo "✓ 블록 갱신: $rc (백업: $rc.bak.binbox)"
}

ensure_exec_bits
link_bb
kind=$(detect_shell)
rc=$(rc_path "$kind")
update_rc "$rc" "$(build_block "$kind")"

echo
echo "완료. 적용하려면:  exec $kind   (또는 source $rc)"
echo "의존성 점검:      bb doctor"
if [[ "$kind" == zsh ]]; then
  echo "완성이 안 보이면:  rm -f ~/.zcompdump && exec zsh"
fi
echo "다른 셸도 쓰면:    bb setup --shell $([[ "$kind" == zsh ]] && echo bash || echo zsh)"
echo "repo를 옮겼다면:   bb setup 재실행 (링크·rc 블록 갱신)"
