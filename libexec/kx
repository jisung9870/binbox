#!/usr/bin/env bash
# kx — Kubernetes 작업 통합 명령 (ctx / ns / log / exec / pf)
set -euo pipefail

_self=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")
BINBOX_DIR=$(cd "$(dirname "$_self")/.." && pwd)
# shellcheck source=../lib/common.sh
source "$BINBOX_DIR/lib/common.sh" || { echo "lib/common.sh not found" >&2; exit 1; }
# shellcheck source=../lib/k8s.sh
source "$BINBOX_DIR/lib/k8s.sh" || { echo "lib/k8s.sh not found" >&2; exit 1; }

usage() {
  cat <<'EOF'
kx — Kubernetes 작업 통합 명령

사용법:
  kx ctx [context]                         # context 선택/전환
  kx ns [namespace]                        # namespace 선택/전환
  kx log [-n <namespace>] [--tail <N>] [pod이름]
  kx exec [-n <namespace>] [pod이름]
  kx pf [-n <namespace>] [pod이름] [로컬포트[:원격포트]]

예시:
  kx ctx my-cluster
  kx ns monitoring
  kx log -n monitoring my-pod-abc123
  kx exec my-pod-abc123
  kx pf my-pod 9000:8080
EOF
}

cmd_ctx() {
  case "${1:-}" in
    -h|--help|help) usage; exit 0 ;;
  esac

  need_cmd kubectl "brew install kubectl"

  local current contexts selected
  current=$(kubectl config current-context 2>/dev/null || true)

  if [[ -n "${1:-}" ]]; then
    kubectl config use-context "$1"
    exit $?
  fi

  need_cmd fzf "brew install fzf"

  contexts=$(kubectl config get-contexts -o name 2>/dev/null || true)
  [[ -n "$contexts" ]] || die "사용 가능한 context가 없습니다."

  selected=$(printf '%s\n' "$contexts" | fzf_pick \
    --prompt="context 선택 (현재: ${current}): " \
    --header="현재: ${current}" \
    --preview="kubectl config get-contexts {}" \
    --preview-window=down:3:wrap)

  if [[ -n "$selected" ]]; then
    kubectl config use-context "$selected"
  fi
}

cmd_ns() {
  case "${1:-}" in
    -h|--help|help) usage; exit 0 ;;
  esac

  need_cmd kubectl "brew install kubectl"

  local current namespaces selected
  current=$(kubectl config view --minify --output 'jsonpath={..namespace}' 2>/dev/null || true)
  current=${current:-default}

  if [[ -n "${1:-}" ]]; then
    kubectl config set-context --current --namespace="$1"
    exit $?
  fi

  need_cmd fzf "brew install fzf"

  namespaces=$(kubectl get namespaces -o jsonpath='{.items[*].metadata.name}' 2>/dev/null | tr ' ' '\n' || true)
  [[ -n "$namespaces" ]] || die "namespace 목록을 가져올 수 없습니다."

  selected=$(printf '%s\n' "$namespaces" | fzf_pick \
    --prompt="namespace 선택 (현재: ${current}): " \
    --header="현재: ${current}" \
    --preview="kubectl get pods -n {} --no-headers 2>/dev/null | head -20" \
    --preview-window=down:10:wrap)

  if [[ -n "$selected" ]]; then
    kubectl config set-context --current --namespace="$selected"
    echo "namespace 전환: $selected"
  fi
}

cmd_log() {
  local namespace="" tail_n=200 pod="" container
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help|help) usage; exit 0 ;;
      -n) [[ -n "${2:-}" ]] || die "-n 뒤에 namespace를 지정하세요."
          namespace="$2"; shift 2 ;;
      --tail) [[ "${2:-}" =~ ^[0-9]+$ ]] || die "--tail 뒤에 숫자를 지정하세요."
          tail_n="$2"; shift 2 ;;
      -*) die "알 수 없는 옵션: $1" ;;
      *) pod="$1"; shift ;;
    esac
  done

  need_cmd kubectl "brew install kubectl"
  need_cmd fzf "brew install fzf"

  if [[ -z "$pod" ]]; then
    pod=$(k8s_pick_pod "$namespace")
    [[ -n "$pod" ]] || exit 0
  fi

  container=$(k8s_pick_container "$namespace" "$pod") || exit 0
  container_args=()
  if [[ -n "$container" ]]; then
    container_args=(-c "$container")
  fi

  ns_args=()
  if [[ -n "$namespace" ]]; then ns_args=(-n "$namespace"); fi

  exec kubectl logs -f --tail="$tail_n" ${ns_args[@]+"${ns_args[@]}"} "$pod" ${container_args[@]+"${container_args[@]}"}
}

cmd_exec() {
  local namespace="" pod="" container
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help|help) usage; exit 0 ;;
      -n) [[ -n "${2:-}" ]] || die "-n 뒤에 namespace를 지정하세요."
          namespace="$2"; shift 2 ;;
      -*) die "알 수 없는 옵션: $1" ;;
      *) pod="$1"; shift ;;
    esac
  done

  need_cmd kubectl "brew install kubectl"
  need_cmd fzf "brew install fzf"

  if [[ -z "$pod" ]]; then
    pod=$(k8s_pick_pod "$namespace")
    [[ -n "$pod" ]] || exit 0
  fi

  container=$(k8s_pick_container "$namespace" "$pod") || exit 0
  container_args=()
  if [[ -n "$container" ]]; then
    container_args=(-c "$container")
  fi

  ns_args=()
  if [[ -n "$namespace" ]]; then ns_args=(-n "$namespace"); fi

  exec kubectl exec -it ${ns_args[@]+"${ns_args[@]}"} "$pod" ${container_args[@]+"${container_args[@]}"} \
    -- sh -c 'exec bash 2>/dev/null || exec sh'
}

cmd_pf() {
  local namespace="" pod="" port_spec="" ports port_count remote_port
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help|help) usage; exit 0 ;;
      -n) [[ -n "${2:-}" ]] || die "-n 뒤에 namespace를 지정하세요."
          namespace="$2"; shift 2 ;;
      -*) die "알 수 없는 옵션: $1" ;;
      *)
        if [[ "$1" =~ ^[0-9]+(:[0-9]+)?$ ]]; then
          port_spec="$1"
        else
          pod="$1"
        fi
        shift ;;
    esac
  done

  need_cmd kubectl "brew install kubectl"
  need_cmd fzf "brew install fzf"

  ns_args=()
  if [[ -n "$namespace" ]]; then ns_args=(-n "$namespace"); fi

  if [[ -z "$pod" ]]; then
    pod=$(k8s_pick_pod "$namespace")
    [[ -n "$pod" ]] || exit 0
  fi

  if [[ -z "$port_spec" ]]; then
    ports=$(kubectl get pod "$pod" ${ns_args[@]+"${ns_args[@]}"} \
      -o jsonpath='{.spec.containers[*].ports[*].containerPort}' 2>/dev/null | tr ' ' '\n' | awk 'NF && !seen[$0]++' || true)
    port_count=$(printf '%s\n' "$ports" | grep -c . || true)
    if [[ "$port_count" -eq 0 ]]; then
      read -r -p "containerPort가 선언되어 있지 않습니다. 원격 포트 입력: " remote_port
      [[ "$remote_port" =~ ^[0-9]+$ ]] || die "올바른 포트 번호가 아닙니다: $remote_port"
    elif [[ "$port_count" -eq 1 ]]; then
      remote_port="$ports"
    else
      remote_port=$(printf '%s\n' "$ports" | fzf_pick --prompt="원격 포트 선택: ")
      [[ -n "$remote_port" ]] || exit 0
    fi
    port_spec="${remote_port}:${remote_port}"
  elif [[ "$port_spec" != *:* ]]; then
    port_spec="${port_spec}:${port_spec}"
  fi

  echo "→ localhost:${port_spec%%:*} → ${pod}:${port_spec##*:} (Ctrl-C로 종료)"
  exec kubectl port-forward ${ns_args[@]+"${ns_args[@]}"} "$pod" "$port_spec"
}

case "${1:-}" in
  ""|-h|--help|help)
    usage
    exit 0
    ;;
  ctx|context)
    shift
    cmd_ctx "$@"
    ;;
  ns|namespace)
    shift
    cmd_ns "$@"
    ;;
  log|logs)
    shift
    cmd_log "$@"
    ;;
  exec|shell)
    shift
    cmd_exec "$@"
    ;;
  pf|port-forward)
    shift
    cmd_pf "$@"
    ;;
  *)
    usage >&2
    die "알 수 없는 서브커맨드: $1"
    ;;
esac
