#!/usr/bin/env bash
# portcheck — 특정 포트를 사용 중인 프로세스 확인
set -euo pipefail

_self=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")
BINBOX_DIR=$(cd "$(dirname "$_self")/.." && pwd)
# shellcheck source=../lib/common.sh
source "$BINBOX_DIR/lib/common.sh" || { echo "lib/common.sh not found" >&2; exit 1; }

usage() {
  echo "사용법: portcheck <포트번호> [--kill]"
  echo "예시: portcheck 8080"
  echo "      portcheck 3000 --kill"
}

case "${1:-}" in
  -h|--help|help) usage; exit 0 ;;
esac

if [[ -z "${1:-}" ]]; then
  usage
  exit 1
fi

PORT="$1"
KILL="${2:-}"

if [[ ! "$PORT" =~ ^[0-9]+$ ]] || ((PORT < 1 || PORT > 65535)); then
  usage >&2
  die "올바른 포트 번호가 아닙니다: $PORT"
fi

if [[ -n "$KILL" && "$KILL" != "--kill" ]]; then
  usage >&2
  die "알 수 없는 옵션: $KILL"
fi

# lsof: macOS는 기본 포함. Linux는 ss로 조회 가능하지만 --kill(PID 추출)은 lsof 필요
if [[ "$(uname)" == "Darwin" ]]; then
  need_cmd lsof "usually preinstalled on macOS"
elif [[ "$KILL" == "--kill" ]] || ! command -v ss >/dev/null; then
  need_cmd lsof "sudo apt install lsof"
fi

if [[ "$(uname)" == "Darwin" ]]; then
  result=$(lsof -i :"$PORT" -P -n 2>/dev/null || true)
else
  result=""
  if command -v ss >/dev/null; then
    result=$(ss -tlnp "sport = :$PORT" 2>/dev/null || true)
  fi
  if [[ -z "$result" ]] || [[ "$result" == *"State"* && $(printf '%s\n' "$result" | wc -l) -le 1 ]]; then
    result=$(lsof -i :"$PORT" -P -n 2>/dev/null || true)
  fi
fi

if [[ -z "$result" ]]; then
  echo "포트 $PORT: 사용 중이지 않음 ✓"
  exit 0
fi

echo "포트 $PORT 사용 중:"
echo "$result"

if [[ "$KILL" == "--kill" ]]; then
  echo ""
  pids=$(lsof -i :"$PORT" -P -n -t 2>/dev/null | awk 'NF && !seen[$0]++ {print}' || true)

  if [[ -n "$pids" ]]; then
    echo "종료 대상 PID:"
    printf '%s\n' "$pids"
    if confirm "위 PID를 모두 종료하시겠습니까?"; then
      failed=0
      while IFS= read -r pid; do
        [[ -n "$pid" ]] || continue
        if kill "$pid"; then
          echo "✓ PID $pid 종료됨"
        else
          echo "✗ PID $pid 종료 실패" >&2
          failed=1
        fi
      done <<<"$pids"
      exit "$failed"
    fi
  fi
fi
