#!/usr/bin/env bash
set -euo pipefail

core_missing=0
optional_missing=0
OS=$(uname -s)

pkg_hint() { # pkg_hint <macOS 힌트> <Linux/WSL 힌트>
  if [[ "$OS" == Darwin ]]; then printf '%s' "$1"; else printf '%s' "$2"; fi
}

check_cmd() {
  local name="$1" scope="$2" hint="${3:-}"

  if command -v "$name" >/dev/null 2>&1; then
    printf '✓ %-13s %s\n' "$name" "$scope"
  else
    printf '✗ %-13s %s' "$name" "$scope"
    if [[ -n "$hint" ]]; then
      printf ' (%s)' "$hint"
    fi
    printf '\n'
    if [[ "$scope" == core:* ]]; then
      core_missing=1
    else
      optional_missing=1
    fi
  fi
}

echo "binbox doctor"
echo
echo "Core tools"
check_cmd docker "core: dx container runner" "$(pkg_hint 'brew install --cask docker' 'Docker Desktop WSL integration 또는 sudo apt install docker.io')"
check_cmd tmux "core: tmux helpers" "$(pkg_hint 'brew install tmux' 'sudo apt install tmux')"
check_cmd fzf "core: interactive selectors" "$(pkg_hint 'brew install fzf' 'sudo apt install fzf')"
check_cmd git "core: gx" "$(pkg_hint 'brew install git' 'sudo apt install git')"
check_cmd lsof "core: portcheck" "$(pkg_hint 'usually preinstalled on macOS' 'sudo apt install lsof')"

echo
echo "Optional tools"
check_cmd kubectl "optional: kx/wenv" "$(pkg_hint 'brew install kubectl' 'sudo snap install kubectl --classic')"
check_cmd terraform "optional: tfx" "$(pkg_hint 'brew install terraform' 'hashicorp apt repo — developer.hashicorp.com/terraform/install')"
check_cmd tf-summarize "optional: tfx sum" "install tf-summarize"
check_cmd aws "optional: assume/assm/wenv/tfx" "$(pkg_hint 'brew install awscli' 'AWS 공식 installer (awscli v2)')"
check_cmd session-manager-plugin "optional: assm" "$(pkg_hint 'brew install session-manager-plugin' 'AWS 공식 .deb 설치')"
check_cmd age "optional: sec" "$(pkg_hint 'brew install age' 'sudo apt install age')"
check_cmd jq "optional: assume/sec" "$(pkg_hint 'brew install jq' 'sudo apt install jq')"
check_cmd shellcheck "optional: binbox-check" "$(pkg_hint 'brew install shellcheck' 'sudo apt install shellcheck')"
check_cmd bats "optional: make test" "$(pkg_hint 'brew install bats-core' 'sudo apt install bats')"

echo
if ((core_missing)); then
  echo "Core dependencies are missing."
  exit 1
fi

if ((optional_missing)); then
  echo "Optional dependencies are missing; core tools are ready."
else
  echo "All checked dependencies are installed."
fi
