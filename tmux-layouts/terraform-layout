#!/usr/bin/env bash
set -euo pipefail

SESSION_NAME="${1:-}"
PROJECT_DIR="${2:-$PWD}"

[[ -n "$SESSION_NAME" ]] || { echo "사용법: terraform-layout <session-name> [project-dir]" >&2; exit 1; }
[[ -d "$PROJECT_DIR" ]] || { echo "프로젝트 디렉토리가 없습니다: $PROJECT_DIR" >&2; exit 1; }
command -v tmux >/dev/null || { echo "tmux가 설치되지 않았습니다." >&2; exit 1; }

# 세션이 이미 있으면 종료
if tmux has-session -t="$SESSION_NAME" 2> /dev/null; then
    echo "Session $SESSION_NAME already exists"
    exit 0
fi

# 새 세션 생성
tmux new-session -d -s "$SESSION_NAME" -c "$PROJECT_DIR" -n "terraform"

# 윈도우 1: 코드 편집 (nvim)
tmux send-keys -t "$SESSION_NAME:1" "nvim" C-m

# 새 윈도우: Terraform 명령어
tmux new-window -t "$SESSION_NAME:2" -n "tf-commands" -c "$PROJECT_DIR"
tmux send-keys -t "$SESSION_NAME:2" "# Terraform commands" C-m

# 세로 분할
tmux split-window -h -t "$SESSION_NAME:2" -c "$PROJECT_DIR"
tmux send-keys -t "$SESSION_NAME:2.2" "# Logs / Outputs" C-m

# 첫 번째 윈도우로 이동
tmux select-window -t "$SESSION_NAME:1"

# 세션으로 전환
tmux switch-client -t "$SESSION_NAME" 2>/dev/null || tmux attach-session -t "$SESSION_NAME"
