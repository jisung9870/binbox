#!/usr/bin/env bash
# md2jira — md-to-jiratext CLI launcher
# 프로젝트 위치가 다르면 MD2JIRA_HOME 환경변수로 덮어쓸 수 있다.
set -euo pipefail
MD2JIRA_HOME="${MD2JIRA_HOME:-$HOME/home/lab/md-to-jiratext}"
MD2JIRA_BIN="$MD2JIRA_HOME/.venv/bin/md2jira"

if [[ ! -x "$MD2JIRA_BIN" ]]; then
  echo "md2jira 실행 파일을 찾을 수 없습니다: $MD2JIRA_BIN" >&2
  echo "md-to-jiratext 프로젝트 위치가 다르면 MD2JIRA_HOME으로 지정하세요." >&2
  echo "예) MD2JIRA_HOME=~/path/to/md-to-jiratext md2jira input.md" >&2
  exit 1
fi

exec "$MD2JIRA_BIN" "$@"
