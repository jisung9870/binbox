#!/usr/bin/env bash
# md2jira — md-to-jiratext CLI launcher
# 프로젝트 위치가 다르면 MD2JIRA_HOME 환경변수로 덮어쓸 수 있다.
set -euo pipefail

_self=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")
BINBOX_DIR=$(cd "$(dirname "$_self")" && pwd)
# shellcheck source=lib/common.sh
source "$BINBOX_DIR/lib/common.sh" || { echo "lib/common.sh not found" >&2; exit 1; }

MD2JIRA_HOME="${MD2JIRA_HOME:-$HOME/home/lab/md-to-jiratext}"
MD2JIRA_BIN="$MD2JIRA_HOME/.venv/bin/md2jira"

if [[ ! -x "$MD2JIRA_BIN" ]]; then
  die "md2jira 실행 파일을 찾을 수 없습니다: $MD2JIRA_BIN" \
    "md-to-jiratext 프로젝트 위치가 다르면 MD2JIRA_HOME으로 지정하세요." \
    "예) MD2JIRA_HOME=~/path/to/md-to-jiratext md2jira input.md"
fi

exec "$MD2JIRA_BIN" "$@"
