#!/usr/bin/env bash
# gitroot — git 저장소 루트 경로 출력
set -euo pipefail

usage() {
  cat <<'EOF'
gitroot — git 저장소 루트 경로 출력

사용법:
  cd $(gitroot)           # 루트 경로 출력
  eval "$(gitroot --cd)"  # cd 명령 출력 (eval로 직접 이동)
EOF
}

case "${1:-}" in
  -h|--help|help) usage; exit 0 ;;
esac

root=$(git rev-parse --show-toplevel 2>/dev/null || true)

if [[ -z "$root" ]]; then
  echo "git 저장소 안에 있지 않습니다." >&2
  exit 1
fi

if [[ "${1:-}" == "--cd" ]]; then
  printf 'cd %q\n' "$root"
else
  echo "$root"
fi
