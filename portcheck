#!/usr/bin/env bash
# portcheck — 특정 포트를 사용 중인 프로세스 확인
set -euo pipefail

usage() {
  echo "사용법: portcheck <포트번호> [--kill]"
  echo "예시: portcheck 8080"
  echo "      portcheck 3000 --kill"
}

if [[ -z "${1:-}" ]]; then
  usage
  exit 1
fi

PORT="$1"
KILL="${2:-}"

if [[ ! "$PORT" =~ ^[0-9]+$ ]] || ((PORT < 1 || PORT > 65535)); then
  echo "올바른 포트 번호가 아닙니다: $PORT" >&2
  usage >&2
  exit 1
fi

if [[ -n "$KILL" && "$KILL" != "--kill" ]]; then
  echo "알 수 없는 옵션: $KILL" >&2
  usage >&2
  exit 1
fi

command -v lsof >/dev/null || { echo "lsof not found in PATH" >&2; exit 1; }

if [[ "$(uname)" == "Darwin" ]]; then
  result=$(lsof -i :"$PORT" -P -n 2>/dev/null || true)
else
  result=""
  if command -v ss >/dev/null; then
    result=$(ss -tlnp "sport = :$PORT" 2>/dev/null || true)
  fi
  if [[ -z "$result" ]] || [[ "$result" == *"State"* && $(printf '%s\n' "$result" | wc -l) -le 1 ]]; then
    result=$(lsof -i :"$PORT" -P -n 2>/dev/null || true)
  fi
fi

if [[ -z "$result" ]]; then
  echo "포트 $PORT: 사용 중이지 않음 ✓"
  exit 0
fi

echo "포트 $PORT 사용 중:"
echo "$result"

if [[ "$KILL" == "--kill" ]]; then
  echo ""
  pids=$(lsof -i :"$PORT" -P -n -t 2>/dev/null | awk 'NF && !seen[$0]++ {print}' || true)

  if [[ -n "$pids" ]]; then
    echo "종료 대상 PID:"
    printf '%s\n' "$pids"
    read -r -p "위 PID를 모두 종료하시겠습니까? (y/n) " -n 1
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      failed=0
      while IFS= read -r pid; do
        [[ -n "$pid" ]] || continue
        if kill "$pid"; then
          echo "✓ PID $pid 종료됨"
        else
          echo "✗ PID $pid 종료 실패" >&2
          failed=1
        fi
      done <<<"$pids"
      exit "$failed"
    fi
  fi
fi
