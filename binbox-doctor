#!/usr/bin/env bash
set -euo pipefail

core_missing=0
optional_missing=0

check_cmd() {
  local name="$1" scope="$2" hint="${3:-}"

  if command -v "$name" >/dev/null 2>&1; then
    printf '✓ %-13s %s\n' "$name" "$scope"
  else
    printf '✗ %-13s %s' "$name" "$scope"
    if [[ -n "$hint" ]]; then
      printf ' (%s)' "$hint"
    fi
    printf '\n'
    if [[ "$scope" == core:* ]]; then
      core_missing=1
    else
      optional_missing=1
    fi
  fi
}

echo "binbox doctor"
echo
echo "Core tools"
check_cmd docker "core: dx container runner" "brew install --cask docker"
check_cmd tmux "core: tmux helpers" "brew install tmux"
check_cmd fzf "core: interactive selectors" "brew install fzf"
check_cmd lsof "core: portcheck" "usually preinstalled on macOS"

echo
echo "Optional tools"
check_cmd kubectl "optional: kctx/kns" "brew install kubectl"
check_cmd terraform "optional: tfplan/tfsum" "brew install terraform"
check_cmd tf-summarize "optional: tfsum" "install tf-summarize"
check_cmd shellcheck "optional: binbox-check" "brew install shellcheck"

echo
if ((core_missing)); then
  echo "Core dependencies are missing."
  exit 1
fi

if ((optional_missing)); then
  echo "Optional dependencies are missing; core tools are ready."
else
  echo "All checked dependencies are installed."
fi
